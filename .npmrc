@kodality-web:registry=https://kexus.kodality.com/repository/npm/

# TODO: Remove legacy-peer-deps once all dependencies support Angular 21.
# Currently needed because:
# - ng-zorro-antd@20.x peers on Angular ^20, but we use Angular 21
#   (ng-zorro-antd@21.x exists but breaks the webpack builder with
#   "Expected named ClassDeclaration" — needs migration to @angular/build:application)
# - @kodality-web/marina-*@16.x packages peer on core-util@^16, but we use core-util@^20
legacy-peer-deps=true
